# Vento Remote MCP Connector - Production Environment Variables
#
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it contains secrets!
#
# cp examples/.env.production.example .env
# nano .env
# chmod 600 .env

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Server listening port
PORT=3000

# Environment: development, production
NODE_ENV=production

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Transport: http (HTTP MCP), stdio (stdio MCP)
MCP_TRANSPORT=http

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# Strong random token for Claude → Connector authentication
# Generate with: openssl rand -hex 32
# Minimum 32 characters, alphanumeric + special chars recommended
MCP_AUTH_TOKEN=your-strong-random-token-min-32-chars

# ============================================================================
# VENTO INTEGRATION
# ============================================================================

# Your Vento instance URL
# Examples: http://localhost:8000 (local dev)
#           https://vento.example.com (production)
#           https://cloud.vento.build (cloud)
VENTO_API_URL=https://your-vento-instance.com

# Vento API token (create in Vento: Settings → API Keys)
# Should have read/write permissions for boards and actions
VENTO_TOKEN=your-vento-api-token

# Optional: Multiple Vento instances (JSON format)
# Format: {"staging":{"url":"https://staging.vento.example.com","token":"token"}}
# Each instance accessible via ?instance=staging parameter in tools
# VENTO_INSTANCES={"staging":{"url":"https://staging.vento.example.com","token":"staging-token"},"prod":{"url":"https://prod.vento.example.com","token":"prod-token"}}

# ============================================================================
# RATE LIMITING
# ============================================================================

# Enable per-token rate limiting
RATE_LIMIT_ENABLED=true

# Maximum requests per minute per token
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Maximum requests per second (burst window) per token
RATE_LIMIT_BURST_PER_SECOND=10

# ============================================================================
# CACHING
# ============================================================================

# Board read cache TTL in seconds
# Set to 0 to disable caching (live reads only)
# Recommended: 30 seconds for balanced freshness vs. performance
CACHE_TTL_SECONDS=30

# ============================================================================
# PERMISSIONS & ACCESS CONTROL
# ============================================================================

# Allow destructive tools (vento_run_action, vento_send_to_agent)
# Set to false for read-only deployments
ALLOW_DESTRUCTIVE_TOOLS=true

# Allowlist specific tools (comma-separated, case-sensitive)
# Leave empty to allow all tools (subject to ALLOW_DESTRUCTIVE_TOOLS)
# Example: vento_list_boards,vento_get_board,vento_get_card_value
# ALLOWED_TOOLS=vento_list_boards,vento_get_board,vento_get_card_value

# ============================================================================
# OAUTH 2.1 (For Directory Submission & OAuth Flows)
# ============================================================================

# Enable OAuth 2.1 PKCE flow
OAUTH_ENABLED=true

# OAuth client ID (from Vento OAuth provider)
# Required for /auth/vento/authorize endpoint
# OAUTH_CLIENT_ID=your-oauth-client-id

# OAuth client secret (from Vento OAuth provider)
# Required for secure token exchange
# OAUTH_CLIENT_SECRET=your-oauth-client-secret

# OAuth callback/redirect URI
# Must be registered with Vento OAuth provider
# Format: https://your-connector-url.com/auth/vento/callback
# OAUTH_REDIRECT_URI=https://your-domain.com/auth/vento/callback

# ============================================================================
# CORS & SECURITY
# ============================================================================

# Allowed CORS origins (comma-separated)
# For Claude integration: https://claude.ai
# For local development: http://localhost:3000
# For custom domains: https://your-domain.com
CORS_ORIGINS=https://claude.ai

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
#
# Before deploying to production:
#
# [ ] MCP_AUTH_TOKEN is strong (32+ chars, random)
# [ ] VENTO_API_URL is HTTPS-only (not HTTP)
# [ ] VENTO_TOKEN is from a dedicated API key (not personal)
# [ ] Connector URL is HTTPS with valid certificate
# [ ] Rate limiting is enabled with appropriate limits
# [ ] LOG_LEVEL is info or warn (not debug in production)
# [ ] NODE_ENV is set to production
# [ ] ALLOWED_TOOLS is configured if needed (empty = all)
# [ ] ALLOW_DESTRUCTIVE_TOOLS is set correctly for your use case
# [ ] Firewall blocks direct port 3000 access (use reverse proxy)
# [ ] Monitoring/alerting is configured
# [ ] Backup strategy for tokens is in place
# [ ] Token rotation schedule is established
#
# ============================================================================

# ============================================================================
# OPTIONAL: DEVELOPMENT/TESTING OVERRIDES
# ============================================================================
# Uncomment these for development environments only!

# LOG_LEVEL=debug
# ALLOW_DESTRUCTIVE_TOOLS=false  # Read-only mode
# RATE_LIMIT_ENABLED=false       # Disable rate limiting for testing
# CACHE_TTL_SECONDS=0            # Disable caching
