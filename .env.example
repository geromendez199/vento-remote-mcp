# Server Configuration
PORT=3000
LOG_LEVEL=info

# MCP Authentication
# Generate with: openssl rand -hex 32
MCP_AUTH_TOKEN=your-secure-token-here-min-32-chars

# Vento Connection
VENTO_API_URL=http://localhost:8000
VENTO_TOKEN=your-vento-api-token

# Optional: Vento Board/Agent Defaults
# If set, API calls will use these as defaults when not specified
# VENTO_DEFAULT_BOARD=
# VENTO_DEFAULT_AGENT=

# Optional: Feature Flags
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS_PER_MINUTE=60
