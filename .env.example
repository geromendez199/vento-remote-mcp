# Server Configuration
PORT=3000
LOG_LEVEL=info

# MCP Authentication
# Generate with: openssl rand -hex 32
MCP_AUTH_TOKEN=your-secure-token-here-min-32-chars

# Vento Connection
VENTO_API_URL=http://localhost:8000
VENTO_TOKEN=your-vento-api-token

# Optional: Vento Board/Agent Defaults
# If set, API calls will use these as defaults when not specified
# VENTO_DEFAULT_BOARD=
# VENTO_DEFAULT_AGENT=

# Optional: Rate Limiting (per client token)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS_PER_MINUTE=60
# RATE_LIMIT_BURST_PER_SECOND=10

# Optional: Board read cache TTL in seconds (0 disables caching)
# CACHE_TTL_SECONDS=30

# Optional: Tool permissions
# Comma-separated allowlist; unset = all tools available
# ALLOWED_TOOLS=vento_list_boards,vento_get_board,vento_get_card_value,vento_list_devices
# Set to false for read-only mode (hides vento_run_action)
# ALLOW_DESTRUCTIVE_TOOLS=true

# Optional: CORS allowlist for browser-based MCP clients
# CORS_ORIGINS=https://claude.ai

# Optional: Extra Vento instances (JSON). Primary instance is always "default".
# VENTO_INSTANCES={"staging":{"url":"https://staging.vento.example.com","token":"tok"}}

# Optional: OAuth 2.0 Configuration
# Set to true to enable OAuth flow for user authorization
# OAUTH_ENABLED=false

# OAuth Client credentials from your Vento instance
# Create in Vento Settings → OAuth Applications
# OAUTH_CLIENT_ID=your-oauth-client-id
# OAUTH_CLIENT_SECRET=your-oauth-client-secret

# OAuth Redirect URI (must match Vento OAuth app settings)
# Example: https://your-connector.railway.app/auth/vento/callback
# OAUTH_REDIRECT_URI=https://your-domain.com/auth/vento/callback
