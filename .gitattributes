# Auto detect text files and normalize line endings to LF
* text=auto

# TypeScript & JavaScript
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Documentation
*.md text eol=lf
*.mdx text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerfile text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Config
.editorconfig text eol=lf
.gitignore text eol=lf
.env.example text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar binary
*.gz binary
